###############################################################################
# Normalize text files to LF in the repository
###############################################################################
* text=auto eol=lf

###############################################################################
# Source code
###############################################################################
*.cs          text eol=lf
*.csproj      text eol=lf
*.sln         text eol=lf
*.props       text eol=lf
*.targets     text eol=lf
*.config      text eol=lf
*.json        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.sql         text eol=lf

###############################################################################
# Frontend / Angular
###############################################################################
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.mjs         text eol=lf
*.cjs         text eol=lf
*.html        text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.sass        text eol=lf
*.less        text eol=lf
*.svg         text eol=lf

###############################################################################
# Scripts
###############################################################################
*.ps1         text eol=crlf
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.sh          text eol=lf

###############################################################################
# GitHub / DevOps
###############################################################################
.github/**    text eol=lf
Dockerfile    text eol=lf
*.dockerfile  text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore    text eol=lf

###############################################################################
# Binary files - do not modify line endings
###############################################################################
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary
*.pdf         binary
*.zip         binary
*.rar         binary
*.7z          binary
*.dll         binary
*.exe         binary
*.pdb         binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary
*.mp4         binary
*.mp3         binary
*.xlsx        binary
*.xls         binary
*.docx        binary
*.doc         binary
*.pptx        binary